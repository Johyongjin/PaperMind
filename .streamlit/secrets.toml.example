# ============================================================
# PaperMind — Streamlit Secrets 템플릿
# ============================================================
# 사용 방법 (로컬):
#   이 파일을 복사하여 .streamlit/secrets.toml 로 저장 후 값 입력
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# 사용 방법 (Streamlit Cloud):
#   앱 대시보드 → Settings → Secrets 에 아래 내용 그대로 붙여넣기
# ============================================================

# ── Anthropic API 키 ─────────────────────────────────────────
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY = "sk-ant-api03-여기에_API_키_입력"

# ── Google Sheets URL ────────────────────────────────────────
GOOGLE_SHEETS_URL = "https://docs.google.com/spreadsheets/d/여기에_ID/edit"

# ── Google 서비스 계정 ────────────────────────────────────────
# service_account.json 파일을 열어 각 항목을 아래에 붙여넣기
# 주의: private_key의 줄바꿈은 반드시 \n 으로 입력해야 합니다
[gcp_service_account]
type                        = "service_account"
project_id                  = "your-project-id"
private_key_id              = "key-id-here"
private_key                 = "-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
client_email                = "your-sa@your-project.iam.gserviceaccount.com"
client_id                   = "123456789012345678901"
auth_uri                    = "https://accounts.google.com/o/oauth2/auth"
token_uri                   = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url        = "https://www.googleapis.com/robot/v1/metadata/x509/your-sa%40your-project.iam.gserviceaccount.com"
