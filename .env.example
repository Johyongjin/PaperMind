# Anthropic API 키
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=sk-ant-api03-여기에_API_키_입력

# 구글 서비스 계정 JSON 파일 경로 (기본값 그대로 사용 권장)
GOOGLE_SERVICE_ACCOUNT_PATH=credentials/service_account.json

# 분석 결과를 저장할 구글 스프레드시트 URL
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/여기에_스프레드시트_ID_입력/edit
